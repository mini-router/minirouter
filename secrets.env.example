# Copy this file to `secrets.env` at the repo root and fill in your keys.
# The Python entrypoints load it automatically.

FIREWORKS_API_KEY=your-fireworks-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
CHUTES_API_KEY=your-chutes-key-here

# Default evaluation routing provider
EVAL_PROVIDER=minibridge
EVAL_MODELS_CONFIG=configs/models.minibridge.light.yaml
PIPELINE_MODE=submission_eval

# MiniBridge protects the upstream provider API key inside the TEE runner.
# MiniRouter sends these policy identities and receives responses plus receipts.
MINIBRIDGE_URL=https://4f4ea5780387d1611e5231be1efe7c883f3f5102-18081.dstack-pha-prod9.phala.network
MINIBRIDGE_PROVIDER_ID=openrouter-prod
MINIBRIDGE_CALLER_ID=minirouter-maintainer
MINIBRIDGE_OWNER_ID=minirouter-miners
MINIBRIDGE_KEY_ID=minirouter-miners-openrouter-key

# Optional:
TRINITY_COST_LEDGER=~/trinity-cost-ledger.jsonl
TRINITY_GPU_HOST=trinity-gpu
TRINITY_REMOTE_DIR=~/trinity
TRINITY_GPU_INDEX=5
EVAL_BATCH_SIZE=4
